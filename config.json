{
    "youtube": {
        "default_query": "La felicidad qué - canserbero",
        "xpath": {
            "icon_volumen": "//button[@class='ytp-volume-icon ytp-button' and (starts-with(@data-tooltip-title, 'Unmute') or @data-tooltip-title='Unmute (m)')]",
            "input_search": "//input[@name='search_query']",
            "first_video": "//ytd-video-renderer",
            "btn_acp_cookies": "//button[contains(., 'Aceptar') or contains(., 'Accept') or contains(., 'Aceptar todas')]"
        }
    },
    "speech": {
        "commands": {
            "saluda": {
                "trigger_words": [
                    "saluda",
                    "saludar",
                    "hola",
                    "dime hola"
                ],
                "action": "/saluda",
                "description": "Saluda al bot"
            },
            "reproduce": {
                "trigger_words": [
                    "reproduce",
                    "pon",
                    "toca",
                    "play",
                    "reproducir",
                    "pon música",
                    "buscar",
                    "search",
                    "encuentra",
                    "busca"
                ],
                "action": "/play",
                "description": "Reproduce música",
                "parameters": {
                    "type": "query"
                }
            },
            "pausa": {
                "trigger_words": [
                    "pausa",
                    "pausar",
                    "detén",
                    "para",
                    "detener"
                ],
                "action": "/pause",
                "description": "Pausa la reproducción"
            },
            "continuar": {
                "trigger_words": [
                    "continuar",
                    "reanudar",
                    "sigue",
                    "resume"
                ],
                "action": "/resume",
                "description": "Reanuda la reproducción"
            },
            "siguiente": {
                "trigger_words": [
                    "siguiente",
                    "next",
                    "siguiente video",
                    "salta"
                ],
                "action": "/next",
                "description": "Reproduce el siguiente video"
            },
            "anterior": {
                "trigger_words": [
                    "anterior",
                    "prev",
                    "anterior video",
                    "atrás",
                    "retrocede"
                ],
                "action": "/prev",
                "description": "Reproduce el video anterior"
            },
            "pantalla completa": {
                "trigger_words": [
                    "pantalla completa",
                    "full screen",
                    "fullscreen",
                    "ampliar"
                ],
                "action": "/fullscreen",
                "description": "Activa pantalla completa"
            },
            "volumen": {
                "trigger_words": [
                    "volumen",
                    "sube volumen",
                    "baja volumen",
                    "volumen a",
                    "set volume"
                ],
                "action": "/volume",
                "description": "Ajusta volumen (ej: 'volumen 50')",
                "parameters": {
                    "type": "integer",
                    "min": 0,
                    "max": 100
                }
            },
            "ayuda": {
                "trigger_words": [
                    "ayuda",
                    "comandos",
                    "qué puedes hacer",
                    "help",
                    "que hacer"
                ],
                "action": "/help",
                "description": "Muestra esta ayuda"
            },
            "apagar": {
                "trigger_words": ["apagar", "apaga", "shutdown", "apagar pc", "apagar equipo", "apagar computadora", "salir", "adios", "apagate", "cierra todo", "basta", "exit", "terminar", "adiós", "hasta luego"],
                "action": "/shutdown",
                "description": "Apaga el ordenador"
            }
        }
    },
    "interctive": "false",
    "browser_user_directory": "~/.config/BraveSoftware/Brave-Browser-Playwright"
}